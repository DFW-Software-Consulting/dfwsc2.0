# ==============================================
# Root .env.example — copy to .env and fill in values
# Used by both backend (API) and frontend (Vite)
# ==============================================

# -----------------------------------------------
# Stripe — get from https://dashboard.stripe.com/apikeys
# -----------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------
# Database
# Docker: keep @db (service name). Local dev without Docker: change to @localhost
# -----------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@db:5432/stripe_portal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stripe_portal

# -----------------------------------------------
# Admin credentials
# -----------------------------------------------
ADMIN_USERNAME=admin
# Dev: plain text. Prod: bcrypt hash — node -e "console.log(require('bcrypt').hashSync('pw',10))"
ADMIN_PASSWORD=changeme
# Must be >= 32 chars. Generate: openssl rand -base64 32
JWT_SECRET=change_me_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRY=1h

# -----------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# Docker dev:    http://localhost:1919,http://localhost:8080
# Prod (nginx):  https://yourdomain.com
# -----------------------------------------------
FRONTEND_ORIGIN=http://localhost:1919,http://localhost:8080

# -----------------------------------------------
# Payment
# -----------------------------------------------
USE_CHECKOUT=true
DEFAULT_PROCESS_FEE_CENTS=100

# -----------------------------------------------
# SMTP
# Local dev:  mailhog values below work out of the box
# Production: replace with real SMTP credentials
# -----------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM=noreply@yourdomain.com

# -----------------------------------------------
# Frontend (Vite)
# Only used for local dev outside Docker.
# Docker builds bake VITE_API_URL in as a build arg — see docker-compose files.
# -----------------------------------------------
VITE_API_URL=http://localhost:4242/api/v1

# -----------------------------------------------
# Optional / advanced
# -----------------------------------------------
# Override the server port (default: 4242)
# PORT=4242

# Override the public API base URL (auto-detected if not set)
# API_BASE_URL=https://api.yourdomain.com

# Set to 'false' to disable Swagger UI (always disabled in production)
# ENABLE_SWAGGER=true

# Enable MailHog integration tests
# MAILHOG_ENABLED=true

# Bootstrap mode — first-run admin account creation (set both, then remove after setup)
# ALLOW_ADMIN_SETUP=true
# ADMIN_SETUP_TOKEN=some_secure_token
