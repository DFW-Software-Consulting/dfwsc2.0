# ==============================================
# Root .env.example — copy to .env and fill in values
# Used by both backend (API) and frontend (Vite)
# ==============================================

# =============================================================================
# STRIPE — REQUIRED for all payment processing
# Get your keys from: https://dashboard.stripe.com/apikeys
# =============================================================================

# Stripe Secret Key — used to create payments, customers, and Checkout Sessions
# Test keys start with sk_test_, Live keys start with sk_live_
# ⚠️ NEVER commit real keys to git — use .env (gitignored)
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret — validates that webhooks are from Stripe
# Get from: Stripe Dashboard → Developers → Webhooks → Select endpoint → Signing secret
# Starts with whsec_
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# DATABASE — REQUIRED for storing clients, invoices, subscriptions, etc.
# Docker: keep @db (service name). Local dev without Docker: change to @localhost
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Docker dev: use @db (matches docker-compose service name)
# Local dev (no Docker): use @localhost
DATABASE_URL=postgresql://postgres:postgres@db:5432/stripe_portal

# Database credentials (used by DATABASE_URL and Docker compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stripe_portal

# =============================================================================
# ADMIN AUTH — REQUIRED for admin dashboard access
# =============================================================================

# Admin login username — used to access /api/v1/auth/login
ADMIN_USERNAME=admin

# Admin login password
# Dev: can be plain text
# Prod: should be a bcrypt hash — generate with:
#   node -e "console.log(require('bcrypt').hashSync('your-password', 10))"
ADMIN_PASSWORD=changeme

# JWT Secret — signs admin session tokens
# ⚠️ Must be at least 32 characters for security
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT Token Expiry — how long admin sessions last
# Examples: 1h, 24h, 7d, 30d
JWT_EXPIRY=1h

# =============================================================================
# CORS / FRONTEND — REQUIRED for browser security
# =============================================================================

# Allowed frontend origins (comma-separated)
# Browser requests from these URLs are allowed to call the API
# Docker dev:    http://localhost:1919,http://localhost:8080
# Prod (nginx):  https://yourdomain.com
FRONTEND_ORIGIN=http://localhost:1919,http://localhost:8080

# =============================================================================
# PAYMENT MODE — REQUIRED to choose Stripe checkout flow
# =============================================================================

# Payment flow mode — controls how customers pay
# true  = Stripe-hosted Checkout (redirect to checkout.stripe.com)
#         ✅ Less code, Stripe handles PCI, built-in fraud protection
#         ❌ Less customization, user leaves your site
# false = PaymentIntent (embed Stripe Elements on your own page)
#         ✅ Full control over checkout UX
#         ❌ More code, you handle card form validation
USE_CHECKOUT=true

# Default platform fee in cents — charged on EVERY payment
# Example: 100 = $1.00, 500 = $5.00, 2500 = $25.00
# This is overridden if a client or group has custom fees set
# Fee priority: Client % → Client flat → Group % → Group flat → This default
DEFAULT_PROCESS_FEE_CENTS=100

# =============================================================================
# EMAIL / SMTP — REQUIRED for sending onboarding emails to clients
# =============================================================================

# SMTP server hostname
# Local dev: mailhog (included in docker-compose)
# Production: your email provider (e.g., smtp.sendgrid.net, smtp.gmail.com)
SMTP_HOST=mailhog

# SMTP server port
# Common ports: 25, 465 (SSL), 587 (TLS), 1025 (MailHog)
SMTP_PORT=1025

# SMTP authentication username
SMTP_USER=test

# SMTP authentication password
SMTP_PASS=test

# "From" address for outgoing emails
# Must be a valid domain you own in production
SMTP_FROM=noreply@yourdomain.com

# =============================================================================
# OPTIONAL / ADVANCED — uncomment and modify as needed
# =============================================================================

# Override the server port (default: 4242)
# PORT=4242

# Override the public API base URL (auto-detected if not set)
# Useful for production deployments behind a reverse proxy
# API_BASE_URL=https://api.yourdomain.com

# Frontend nginx proxy URL (Docker deployments only)
# Used by nginx.conf to proxy /api/v1 requests to the backend
# Docker dev default: http://api:4242
# Coolify prod: http://<your-api-service-name>:4242
# API_URL=http://api:4242

# Enable/disable Swagger UI documentation
# true  = available at http://localhost:4242/docs (dev only)
# false = disabled (always disabled in production)
# ENABLE_SWAGGER=true

# Enable MailHog integration tests
# true  = enables email-related integration tests
# false = skips email tests
# MAILHOG_ENABLED=true

# Bootstrap mode — allows first-run admin account creation via API
# ⚠️ SECURITY: Set both, create admin account, then REMOVE or set to false
# Used only for initial deployment when ADMIN_PASSWORD is not yet set
# ALLOW_ADMIN_SETUP=true
# ADMIN_SETUP_TOKEN=some_secure_token

# =============================================================================
# FRONTEND (Vite) — used during build and injected at runtime
# =============================================================================

# API base URL — must match the backend API address accessible from the browser
# Docker dev: http://localhost:4242/api/v1
# Production: https://api.yourdomain.com/api/v1
VITE_API_URL=http://localhost:4242/api/v1
